      }
    },
    "ios": {
      "bundleIdentifier": "com.target",
      "supportsTablet": true,
      "icon": "./assets/ios-icon.png"
    },
    "plugins": [
      "expo-router",
      "expo-status-bar"
    ]
  }
}
