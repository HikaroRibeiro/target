{
  "expo": {
    "scheme": "target",
    "experiments": {
      "typedRoutes": true
    },
    "name": "target",
    "slug": "target",
    "version": "1.0.0",
    "android": {
      "package": "com.target",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
